{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "scratchpad/**/*.ts",
      "tests/**/*.ts",
      "*.json",
      ".vscode/**/*.json"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5"
    }
  },
  "linter": {
    "rules": {
      "complexity": {
        "noArguments": "off"
      },
      "style": {
        "useDefaultSwitchClause": "off",
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false
          }
        },
        "noMagicNumbers": "off",
        "useFilenamingConvention": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      },
      "suspicious": {
        "noUnsafeDeclarationMerging": "off",
        "noShadowRestrictedNames": "off",
        "noSkippedTests": "warn"
      }
    }
  }
}
