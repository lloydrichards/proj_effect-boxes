{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5"
    }
  },
  "linter": {
    "rules": {
      "complexity": {
        "noArguments": "off",
        "useRegexLiterals": "off"
      },
      "correctness": {
        "useYield": "off"
      },
      "style": {
        "useDefaultSwitchClause": "off",
        "noMagicNumbers": "off",
        "useFilenamingConvention": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      },
      "suspicious": {
        "noUnsafeDeclarationMerging": "off",
        "noShadowRestrictedNames": "off",
        "noSkippedTests": "warn"
      }
    }
  }
}
