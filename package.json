{
  "name": "effect-boxes",
  "version": "0.11.0",
  "description": "A functional TypeScript library for creating and manipulating text-based box layouts using Effect.js patterns",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Box": {
      "types": "./src/Box.ts",
      "import": "./src/Box.ts"
    },
    "./Annotation": {
      "types": "./src/Annotation.ts",
      "import": "./src/Annotation.ts"
    },
    "./Ansi": {
      "types": "./src/Ansi.ts",
      "import": "./src/Ansi.ts"
    },
    "./Cmd": {
      "types": "./src/Cmd.ts",
      "import": "./src/Cmd.ts"
    },
    "./Reactive": {
      "types": "./src/Reactive.ts",
      "import": "./src/Reactive.ts"
    },
    "./Html": {
      "types": "./src/Html.ts",
      "import": "./src/Html.ts"
    },
    "./Renderer": {
      "types": "./src/Renderer.ts",
      "import": "./src/Renderer.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*.ts"
  ],
  "keywords": [
    "effect",
    "typescript",
    "functional",
    "box-layout",
    "terminal",
    "ansi",
    "text-rendering"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lloydrichards/effect-boxes.git"
  },
  "homepage": "https://github.com/lloydrichards/effect-boxes#readme",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/lloydrichards/effect-boxes/issues"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "clean": "git clean -xdf .cache dist node_modules tsconfig.tsbuildinfo",
    "lint": "biome lint",
    "docs:check": "bun run scripts/check-tsdoc.ts",
    "type-check": "tsc --noEmit",
    "format": "biome check --write",
    "test": "vitest run",
    "scratch": "bun run scratchpad/index.ts",
    "benchmark": "vitest bench --run",
    "benchmark:quick": "vitest bench benchmarks/quick.bench.ts --run",
    "postinstall": "effect-language-service patch",
    "prepack": "bun run type-check"
  },
  "dependencies": {
    "effect": "4.0.0-beta.59"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.85.1",
    "@effect/platform-bun": "4.0.0-beta.59",
    "@microsoft/tsdoc": "^0.16.0",
    "@microsoft/tsdoc-config": "^0.18.1",
    "@types/bun": "^1.3.13",
    "@vitest/coverage-v8": "4.1.5",
    "tinybench": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
